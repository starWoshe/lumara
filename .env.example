# =========================================
# LUMARA Academy — Змінні середовища
# Скопіюй цей файл у .env.local та заповни значення
# =========================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (Prisma) ---
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- NextAuth ---
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- OpenAI (GPT-4 для UMBRA) ---
OPENAI_API_KEY=your-openai-api-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_LIVE_MODE=false

# --- Resend (Email) ---
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@lumara.fyi

# --- Cron (keep Supabase alive) ---
CRON_SECRET=your-random-cron-secret

# --- Telegram (боти магів) ---
LUNA_TELEGRAM_BOT_TOKEN=your-luna-bot-token
ARCAS_TELEGRAM_BOT_TOKEN=your-arcas-bot-token
NUMI_TELEGRAM_BOT_TOKEN=your-numi-bot-token
UMBRA_TELEGRAM_BOT_TOKEN=your-umbra-bot-token

# --- Telegram (канали публікації) ---
LUNA_TELEGRAM_CHANNEL_ID=@luna_lumara
ARCAS_TELEGRAM_CHANNEL_ID=-1003764526911
NUMI_TELEGRAM_CHANNEL_ID=-1003955376716
UMBRA_TELEGRAM_CHANNEL_ID=-1003966644443
LUMARA_TELEGRAM_CHANNEL_ID=-1003522439677

# --- Telegram (моніторинг груп, загальний бот) ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_MONITORED_GROUPS=[-1001234567890,-1009876543210]
TELEGRAM_MAX_PER_HOUR=5

# --- UserBot (Telethon клієнти магів) ---
USERBOT_ENABLED=true
ACTIVE_USERBOTS=luna
LUNA_USERBOT_MODE=warmup
LUNA_API_ID=your-telegram-api-id
LUNA_API_HASH=your-telegram-api-hash
ARCAS_USERBOT_MODE=warmup
ARCAS_API_ID=your-telegram-api-id
ARCAS_API_HASH=your-telegram-api-hash
NUMI_USERBOT_MODE=warmup
NUMI_API_ID=your-telegram-api-id
NUMI_API_HASH=your-telegram-api-hash
UMBRA_USERBOT_MODE=warmup
UMBRA_API_ID=your-telegram-api-id
UMBRA_API_HASH=your-telegram-api-hash

# --- Academy API (Telegram) ---
ACADEMY_API_ID=your-telegram-api-id
ACADEMY_API_HASH=your-telegram-api-hash

# --- Telegram Webhook Security ---
# Секретний токен для перевірки webhook запитів від Telegram
# Встанови через BotFather / setWebhook з параметром secret_token
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret-min-32-chars

# --- Instagram (автовідповіді на коментарі) ---
IG_ACCESS_TOKEN=your-instagram-user-access-token
LUNA_IG_USER_ID=your-luna-instagram-user-id
ARCAS_IG_USER_ID=your-arcas-instagram-user-id
NUMI_IG_USER_ID=your-numi-instagram-user-id
UMBRA_IG_USER_ID=your-umbra-instagram-user-id

# --- Meta (публікація постів) ---
LUNA_PAGE_ACCESS_TOKEN=your-luna-page-token
LUNA_PAGE_ID=your-luna-page-id
ARCAS_PAGE_ACCESS_TOKEN=your-arcas-page-token
ARCAS_PAGE_ID=your-arcas-page-id
NUMI_PAGE_ACCESS_TOKEN=your-numi-page-token
NUMI_PAGE_ID=your-numi-page-id
UMBRA_PAGE_ACCESS_TOKEN=your-umbra-page-token
UMBRA_PAGE_ID=your-umbra-page-id
LUMARA_PAGE_ACCESS_TOKEN=your-lumara-page-token
LUMARA_PAGE_ID=your-lumara-page-id
LUMARA_IG_USER_ID=your-lumara-ig-user-id

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LUMARA Academy
ADMIN_EMAIL=your-admin-email@example.com
