{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/health",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/reactivation",
      "schedule": "0 12 * * *"
    }
  ]
}
