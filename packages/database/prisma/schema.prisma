// Prisma схема для LUMARA Academy
// Документація: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =========================================
// КОРИСТУВАЧІ ТА ПРОФІЛІ
// =========================================

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  role          UserRole  @default(USER)
  tenantId      String?   @map("tenant_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")
  reactivationSentAt    DateTime? @map("reactivation_sent_at")
  emailUnsubscribedAt   DateTime? @map("email_unsubscribed_at")

  // Зв'язки
  profile             Profile?
  accounts            Account[]
  sessions            Session[]
  conversations       Conversation[]
  subscriptions       Subscription[]
  enrollments         Enrollment[]
  activityLogs        ActivityLog[]
  announcementStates  AnnouncementState[]

  @@map("users")
}

// =========================================
// ЛОГ АКТИВНОСТІ КОРИСТУВАЧІВ
// =========================================

enum ActivityAction {
  SIGN_IN              // Вхід в систему
  SIGN_OUT             // Вихід
  CHAT_STARTED         // Почав чат з агентом
  MESSAGE_SENT         // Надіслав повідомлення
  PROFILE_UPDATED      // Оновив профіль
  SUBSCRIPTION_CHANGED // Змінив підписку
}

model ActivityLog {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  action    ActivityAction
  metadata  Json?          // Додаткові дані (агент, план тощо)
  ipAddress String?        @map("ip_address")
  userAgent String?        @map("user_agent")
  createdAt DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// =========================================
// NEXTAUTH — АВТОРИЗАЦІЯ
// =========================================

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Profile {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  fullName    String?   @map("full_name")
  gender      String?
  birthDate   DateTime? @map("birth_date")
  birthTime   String?   @map("birth_time")
  birthPlace  String?   @map("birth_place")
  goal              String?
  acquisitionSource String?   @map("acquisition_source")
  language         String    @default("uk")
  timezone         String    @default("Europe/Kiev")
  lastVisitedAgent AgentType? @map("last_visited_agent")
  tenantId         String?   @map("tenant_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// =========================================
// AI АГЕНТИ
// =========================================

enum AgentType {
  LUNA   // Астрологія
  ARCAS  // Таро / Оракул
  NUMI   // Нумерологія
  UMBRA  // Езо-психологія
}

enum AIModel {
  CLAUDE_CLAUDE_OPUS_4_6
  CLAUDE_SONNET_4_6
  GPT4
}

model Agent {
  id          String    @id @default(uuid())
  type        AgentType @unique
  name        String
  description String?
  model       AIModel   @default(CLAUDE_SONNET_4_6)
  promptFile  String    @map("prompt_file")
  isActive     Boolean   @default(true) @map("is_active")
  tokenLimit   Int       @default(4000) @map("token_limit")
  blockedUntil DateTime? @map("blocked_until")
  tenantId     String?   @map("tenant_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  conversations Conversation[]

  @@map("agents")
}

// =========================================
// СЕСІЇ ТА ПОВІДОМЛЕННЯ
// =========================================

model Conversation {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  agentId   String    @map("agent_id")
  title     String?
  tokenUsed Int       @default(0) @map("token_used")
  tenantId  String?   @map("tenant_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    Agent     @relation(fields: [agentId], references: [id])
  messages Message[]

  @@map("conversations")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        String
  tokenCount     Int?        @map("token_count")
  tenantId       String?     @map("tenant_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// =========================================
// ПІДПИСКИ (STRIPE)
// =========================================

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  ELITE
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @map("user_id")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  tenantId             String?            @map("tenant_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  deletedAt            DateTime?          @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// =========================================
// КУРСИ ТА ЗАПИСИ
// =========================================

model Course {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  description String?
  coverImage  String?   @map("cover_image")
  agentType   AgentType? @map("agent_type")
  isPublished Boolean   @default(false) @map("is_published")
  price       Int       @default(0) // у центах
  tenantId    String?   @map("tenant_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  enrollments Enrollment[]

  @@map("courses")
}

model Enrollment {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  courseId    String    @map("course_id")
  completedAt DateTime? @map("completed_at")
  tenantId    String?   @map("tenant_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

// =========================================
// КОНТЕНТ ДЛЯ СОЦМЕРЕЖ
// =========================================

enum ContentStatus {
  DRAFT
  QUEUED
  PUBLISHED
  FAILED
}

enum ContentPlatform {
  INSTAGRAM
  TELEGRAM
  TWITTER
  FACEBOOK
}

model ContentQueue {
  id          String          @id @default(uuid())
  agentType   AgentType       @map("agent_type")
  platform    ContentPlatform
  content     String
  mediaUrl    String?         @map("media_url")
  status      ContentStatus   @default(DRAFT)
  scheduledAt DateTime?       @map("scheduled_at")
  publishedAt DateTime?       @map("published_at")
  tenantId    String?         @map("tenant_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  @@map("content_queue")
}

model TokenUsage {
  id           String    @id @default(uuid())
  userId       String?   @map("user_id")
  agent        AgentType
  actionType   String    @default("chat") @map("action_type")
  model        String
  tokensInput  Int       @map("tokens_input")
  tokensOutput Int       @map("tokens_output")
  tokensTotal  Int       @map("tokens_total")
  costUsd      Float     @map("cost_usd")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([agent])
  @@index([createdAt])
  @@index([userId])
  @@map("token_usage")
}

// =========================================
// АКТИВНИЙ ПОШУК КЛІЄНТІВ (OUTREACH)
// =========================================

enum OutreachPlatform {
  TELEGRAM_GROUP
  INSTAGRAM_COMMENT
}

enum OutreachLanguage {
  UK
  RU
  EN
  DE
}

model OutreachResponse {
  id               String           @id @default(uuid())
  platform         OutreachPlatform
  agentType        AgentType        @map("agent_type")
  language         OutreachLanguage
  groupHandle      String?          @map("group_handle")
  externalPostId   String?          @map("external_post_id")
  externalThreadId String?          @map("external_thread_id")
  triggerPhrase    String?          @map("trigger_phrase")
  responseText     String           @map("response_text") @db.Text
  targetUrl        String?          @map("target_url")
  userHandle       String?          @map("user_handle")
  createdAt        DateTime         @default(now()) @map("created_at")

  @@index([platform, createdAt])
  @@index([agentType, createdAt])
  @@index([language])
  @@map("outreach_responses")
}

model ReferralClick {
  id        String     @id @default(uuid())
  source    String
  agentType AgentType? @map("agent_type")
  utmSource String?    @map("utm_source")
  utmMedium String?    @map("utm_medium")
  ipAddress String?    @map("ip_address")
  userAgent String?    @map("user_agent")
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([source, createdAt])
  @@index([agentType])
  @@map("referral_clicks")
}

model AdminSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("admin_settings")
}

// =========================================
// АНОНСИ МАГІВ — трекінг показаних шарів
// =========================================

model AnnouncementState {
  id                       String    @id @default(uuid())
  userId                   String    @map("user_id")
  agentType                AgentType @map("agent_type")
  lastLayer                Int       @default(0) @map("last_layer")
  lastAnnouncementExchange Int       @default(0) @map("last_announcement_exchange")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentType])
  @@map("announcement_states")
}

// =========================================
// СТЕЙТ МОНІТОРИНГУ (GitHub Actions — stateless)
// =========================================

model MonitorState {
  platform  String   @id
  state     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("monitor_states")
}

// =========================================
// TELEGRAM ГРУПИ (збір даних для аналізу)
// =========================================

model TelegramGroup {
  id             String    @id @default(uuid())
  externalId     String    @unique @map("external_id")
  title          String?
  username       String?
  memberCount    Int?      @map("member_count")
  keywords       Json?     // Ключові слова / хештеги
  category       String?   // Астрологія, Таро, Нумерологія, Езотерика, Вузька ніша
  isNiche        Boolean   @default(false) @map("is_niche")
  lastActivityAt DateTime? @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@index([isNiche])
  @@index([lastActivityAt])
  @@map("telegram_groups")
}

// =========================================
// СПІЛЬНА ПАМ'ЯТЬ МАГІВ (User Context)
// =========================================

model UserContext {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  mage              AgentType
  platform          String    // TELEGRAM, INSTAGRAM, FACEBOOK, WEB
  lastTopic         String?   @map("last_topic")
  artifactHintShown Boolean   @default(false) @map("artifact_hint_shown")
  messageCount      Int       @default(0) @map("message_count")
  lastInteraction   DateTime  @updatedAt @map("last_interaction")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@unique([userId, mage, platform])
  @@index([userId])
  @@index([mage])
  @@map("user_context")
}

// =========================================
// TELEGRAM WEBHOOK РОЗМОВИ
// =========================================

model TelegramConversation {
  id        String    @id @default(uuid())
  chatId    String    @map("chat_id")
  mage      AgentType
  messages  Json      // [{role: 'user'|'assistant', content: string, createdAt: string}]
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([chatId, mage])
  @@index([chatId])
  @@index([mage])
  @@map("telegram_conversations")
}
